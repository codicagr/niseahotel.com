{
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "css:prefix": "postcss public_html/themes/default/css/*.css --use autoprefixer -d public_html/themes/default/css/",
        "sass:build": "sass resources/sass/themes/default/styles.scss:public_html/themes/default/css/styles.min.css --style compressed && postcss public_html/themes/default/css/styles.min.css --use autoprefixer -o public_html/themes/default/css/styles.min.css",
        "sass:compile": "sass resources/sass/themes/default/styles.scss:public_html/themes/default/css/styles.css",
        "prefix:css": "postcss public_html/themes/default/css/styles.css --use autoprefixer -o public_html/themes/default/css/styles.css",
        "sass:watch": "chokidar \"resources/sass/**/*.scss\" -c \"npm run sass:compile && npm run prefix:css\""
    },
    "devDependencies": {
        "autoprefixer": "^10.4.24",
        "chokidar-cli": "^3.0.0",
        "laravel-vite-plugin": "^1.0.0",
        "postcss": "^8.5.6",
        "postcss-cli": "^11.0.1",
        "sass": "^1.93.2",
        "vite": "^5.0.0"
    },
    "dependencies": {
        "@alpinejs/anchor": "^3.14.9",
        "@alpinejs/collapse": "^3.15.0",
        "@alpinejs/focus": "^3.15.0",
        "@alpinejs/intersect": "^3.15.0",
        "@alpinejs/persist": "^3.15.0",
        "@codicagr/cms-core-toolkit": "^0.2.23",
        "@fancyapps/ui": "^6.1.13",
        "@googlemaps/js-api-loader": "^2.0.2",
        "@googlemaps/markerclusterer": "^2.6.2",
        "@splidejs/splide": "^4.1.4",
        "alpinejs": "^3.15.0",
        "async-alpine": "^2.0.3",
        "flatpickr": "^4.6.13",
        "gsap": "^3.14.2",
        "headroom.js": "^0.12.0",
        "lenis": "^1.3.18"
    },
    "browserslist": [
        "last 2 versions",
        "> 0.5%",
        "not dead"
    ]
}
